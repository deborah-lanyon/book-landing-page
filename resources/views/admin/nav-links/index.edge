                      <div class="form-row">
                        <div class="form-group flex-1">
                          <label>Sub-link Label</label>
                          <input type="text" name="label" placeholder="e.g. Article Title" required>
                        </div>
                        <div class="form-group flex-1">
                          <label>URL</label>
                          <input type="text" name="url" placeholder="https://example.com" required>
                        </div>
                        <div class="form-group">
                          <label class="checkbox-label">
                            <input type="checkbox" name="openInNewTab" checked>
                            New tab
                          </label>
                        </div>
                        <div class="form-group">
                          <button type="submit" class="btn btn-sm btn-purple">Add</button>
