                      <div class="link-url">{{ link.url }}</div>
                    </div>
                    @if(link.openInNewTab)
                      <span class="link-badge">New tab</span>
                    @end
                    @if(link.children && link.children.length > 0)
                      <span class="link-badge">{{ link.children.length }} sub-link{{ link.children.length > 1 ? 's' : '' }}</span>
                    @end
