                      </div>
                    </form>
                  </div>

                  {{-- Existing sub-links --}}
                  @if(link.children && link.children.length > 0)
                    @each(child in link.children)
                      <div class="sublink-row">
                        <span class="sublink-indicator">└</span>
                        <div class="link-info">
                          <div class="link-label">{{ child.label }}</div>
                          <div class="link-url">{{ child.url }}</div>
                        </div>
                        @if(child.openInNewTab)
                          <span class="link-badge">New tab</span>
                        @end
                        <div class="link-actions">
                          <button class="btn btn-sm btn-outline" onclick="toggleEdit({{ child.id }})">Edit</button>
                          <form method="POST" action="{{ route('admin.navlinks.destroy', { id: child.id }) }}" style="margin:0;" onsubmit="return confirm('Remove this sub-link?')">
                            {{ csrfField() }}
                            <input type="hidden" name="_method" value="DELETE">
                            <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                          </form>
                        </div>
                      </div>
                      <div class="edit-form" id="edit-{{ child.id }}">
                        <form method="POST" action="{{ route('admin.navlinks.update', { id: child.id }) }}">
                          {{ csrfField() }}
                          <input type="hidden" name="_method" value="PUT">
                          <div class="form-row" style="padding-left: 30px;">
                            <div class="form-group flex-1">
                              <label>Label</label>
                              <input type="text" name="label" value="{{ child.label }}" required>
                            </div>
                            <div class="form-group flex-1">
                              <label>URL</label>
                              <input type="text" name="url" value="{{ child.url }}" required>
                            </div>
                            <div class="form-group">
                              <label class="checkbox-label">
                                <input type="checkbox" name="openInNewTab" {{ child.openInNewTab ? 'checked' : '' }}>
                                New tab
                              </label>
                            </div>
                            <div class="form-group">
                              <button type="submit" class="btn btn-sm">Save</button>
                            </div>
                          </div>
                        </form>
                      </div>
                    @end
                  @end
                @end
              </div>
            @else
              <div class="empty-note">No menu links yet. Add one below.</div>
            @end
          </div>
        </div>

        <div class="card">
          <div class="card-header">Add New Link</div>
          <div class="card-body">
            <form method="POST" action="{{ route('admin.navlinks.store') }}">
              {{ csrfField() }}
              <div class="form-row">
                <div class="form-group flex-1">
                  <label>Label</label>
                  <input type="text" name="label" placeholder="e.g. Further Reading" required>
                </div>
                <div class="form-group flex-1">
                  <label>URL</label>
                  <input type="text" name="url" placeholder="https://example.com" required>
                </div>
                <div class="form-group">
                  <label class="checkbox-label">
                    <input type="checkbox" name="openInNewTab" checked>
                    New tab
                  </label>
                </div>
                <div class="form-group">
                  <button type="submit" class="btn">Add Link</button>
                </div>
              </div>
            </form>
          </div>
        </div>

      </div>
    </div>
  </div>

  <script>
    function toggleEdit(id) {
      var el = document.getElementById('edit-' + id);
      el.classList.toggle('active');
    }

    function toggleSubForm(id) {
      var el = document.getElementById('subform-' + id);
      el.classList.toggle('active');
    }

    // Drag and drop reordering
    var list = document.getElementById('linkList');
    if (list) {
      var dragEl = null;
      list.querySelectorAll('.link-row').forEach(function(row) {
        row.addEventListener('dragstart', function(e) {
          dragEl = this;
          this.classList.add('dragging');
          e.dataTransfer.effectAllowed = 'move';
        });
        row.addEventListener('dragend', function() {
          this.classList.remove('dragging');
          list.querySelectorAll('.link-row').forEach(function(r) { r.classList.remove('drag-over'); });
        });
        row.addEventListener('dragover', function(e) {
          e.preventDefault();
          e.dataTransfer.dropEffect = 'move';
          if (this !== dragEl) {
            this.classList.add('drag-over');
          }
        });
        row.addEventListener('dragleave', function() {
          this.classList.remove('drag-over');
        });
        row.addEventListener('drop', function(e) {
          e.preventDefault();
          this.classList.remove('drag-over');
          if (dragEl !== this) {
            list.insertBefore(dragEl, this);
            saveOrder();
          }
        });
      });
    }

    function saveOrder() {
      var rows = document.querySelectorAll('#linkList .link-row');
      var ids = [];
      rows.forEach(function(r) { ids.push(Number(r.dataset.id)); });
      fetch('{{ route("admin.navlinks.reorder") }}', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-TOKEN': '{{ csrfToken }}'
        },
        body: JSON.stringify({ ids: ids })
      });
    }
  </script>
</body>
</html>
