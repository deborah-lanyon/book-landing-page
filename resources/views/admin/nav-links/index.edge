                            New tab
                          </label>
                        </div>
                        <div class="form-group">
                          <button type="submit" class="btn btn-sm">Save</button>
                        </div>
                      </div>
                    </form>
                  </div>

                  {{-- Sub-link add form --}}
                  <div class="sublink-form" id="subform-{{ link.id }}">
                    <form method="POST" action="{{ route('admin.navlinks.store') }}">
                      {{ csrfField() }}
