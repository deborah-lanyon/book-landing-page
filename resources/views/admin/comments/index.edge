                </div>
                <span class="comment-date">{{ comment.createdAt.toFormat('dd MMM yyyy HH:mm') }}</span>
              </div>
              <div class="comment-content" id="content-{{ comment.id }}">{{ comment.content }}</div>
              <div class="edit-form" id="edit-{{ comment.id }}">
                <form method="POST" action="{{ route('admin.comments.update', { id: comment.id }) }}">
                  {{ csrfField() }}
                  <input type="hidden" name="_method" value="PUT">
                  <textarea name="content">{{ comment.content }}</textarea>
                  <div class="edit-actions">
                    <button type="submit" class="btn btn-success btn-small">Save</button>
                    <button type="button" class="btn btn-small" onclick="toggleEdit({{ comment.id }})" style="background: #95a5a6;">Cancel</button>
                  </div>
                </form>
              </div>
              <div class="comment-actions">
                <button type="button" class="btn btn-small" onclick="toggleEdit({{ comment.id }})">Edit</button>
                <button type="button" class="btn btn-small" onclick="toggleReply({{ comment.id }})" style="background: #8e44ad;">Reply</button>
                <form method="POST" action="{{ route('admin.comments.destroy', { id: comment.id }) }}" style="margin: 0;" onsubmit="return confirm('Delete this comment and all its replies?')">
                  {{ csrfField() }}
                  <input type="hidden" name="_method" value="DELETE">
                  <button type="submit" class="btn btn-danger btn-small">Delete</button>
                </form>
              </div>

              {{-- Existing replies --}}
              @each(reply in comment.replies)
                <div class="reply-card {{ reply.isAdminReply ? 'admin-reply' : '' }}">
                  <div class="comment-meta">
                    <div>
                      <span class="comment-author">{{ reply.authorName }}</span>
                      @if(reply.isAdminReply)
                        <span class="admin-badge">Admin</span>
                      @end
                    </div>
                    <span class="comment-date">{{ reply.createdAt.toFormat('dd MMM yyyy HH:mm') }}</span>
                  </div>
                  <div class="comment-content" id="content-{{ reply.id }}">{{ reply.content }}</div>
                  <div class="edit-form" id="edit-{{ reply.id }}">
                    <form method="POST" action="{{ route('admin.comments.update', { id: reply.id }) }}">
                      {{ csrfField() }}
                      <input type="hidden" name="_method" value="PUT">
                      <textarea name="content">{{ reply.content }}</textarea>
                      <div class="edit-actions">
                        <button type="submit" class="btn btn-success btn-small">Save</button>
                        <button type="button" class="btn btn-small" onclick="toggleEdit({{ reply.id }})" style="background: #95a5a6;">Cancel</button>
                      </div>
                    </form>
                  </div>
                  <div class="comment-actions" style="margin-top: 8px;">
                    <button type="button" class="btn btn-small" onclick="toggleEdit({{ reply.id }})">Edit</button>
                    <form method="POST" action="{{ route('admin.comments.destroy', { id: reply.id }) }}" style="margin: 0;" onsubmit="return confirm('Delete this reply?')">
                      {{ csrfField() }}
                      <input type="hidden" name="_method" value="DELETE">
                      <button type="submit" class="btn btn-danger btn-small">Delete</button>
                    </form>
                  </div>
                </div>
              @end

              {{-- Reply form --}}
              <div class="reply-form" id="reply-{{ comment.id }}">
                <form method="POST" action="{{ route('admin.comments.reply', { id: comment.id }) }}">
                  {{ csrfField() }}
                  <textarea name="content" placeholder="Write your reply..."></textarea>
                  <div class="reply-actions">
                    <button type="submit" class="btn btn-success btn-small">Post Reply</button>
                    <button type="button" class="btn btn-small" onclick="toggleReply({{ comment.id }})" style="background: #95a5a6;">Cancel</button>
                  </div>
                </form>
              </div>
            </div>
          @end
        @end
      </div>
    </div>
      </div>
    </div>
  </div>

  <script>
    function toggleReply(commentId) {
      const form = document.getElementById('reply-' + commentId);
      form.classList.toggle('open');
    }

    function toggleEdit(commentId) {
      const content = document.getElementById('content-' + commentId);
      const form = document.getElementById('edit-' + commentId);
      content.style.display = content.style.display === 'none' ? '' : 'none';
      form.classList.toggle('open');
    }
  </script>
</body>
</html>
